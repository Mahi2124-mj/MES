# ────────────────────────────────────────────────────────────────────
# EOL MES Repository — .gitignore
# ────────────────────────────────────────────────────────────────────

# ── Secrets / credentials (NEVER push) ──────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secret*
*secret*
credentials*
*credentials*

# ── Python ──────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.bak
*.backup
*.OLD_*
*.old
*~

# ── Node.js / Vite ──────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Logs ────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
_collector.log

# ── IDE / OS ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── Local config that varies per machine ────────────────────────────
shift_state.json
cycle_state.json
*.local.json

# ── Build outputs / temp ────────────────────────────────────────────
build/
out/
tmp/
temp/
*.tmp

# ── Database dumps ──────────────────────────────────────────────────
*.sql.gz
*.dump
*.bak.sql

# ── Bat file backups created during edits ───────────────────────────
*.bat.bak_*
*.py.bak_*
*.jsx.bak_*

# ── Project-specific ────────────────────────────────────────────────
collector_engine.py.OLD_DUPLICATE_*
