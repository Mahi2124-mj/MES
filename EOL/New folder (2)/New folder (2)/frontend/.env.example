# Toyota Boshoku EMS — Frontend Environment Variables
# Copy this file to .env and fill in production values.

# Flask API base URL (leave as /api when using Vite proxy in dev)
VITE_API_BASE_URL=/api

# Dash MJPEG stream server URL
# Change host/port if dashboard_legacy.py runs on a different machine or port
VITE_STREAM_BASE_URL=http://localhost:8050
