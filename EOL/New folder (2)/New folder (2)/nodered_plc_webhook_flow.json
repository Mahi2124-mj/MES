    {
        "id": "tb_edge_detect_l109",
        "type": "function",
        "z": "tb_ems_plc_flow",
        "name": "Rising Edge L109",
        "func": "var prev = context.get('prev');\nvar curr = msg.payload.L109;\n\nif (prev !== curr) {\n    context.set('prev', curr);\n    \n    msg.method = 'POST';\n    msg.url = 'http://127.0.0.1:5000/api/plc-webhook';\n    msg.payload = {\n        plc_id: 'plc_1775730498875',\n        bit: 'L109',\n        value: curr\n    };\n    msg.headers = {'Content-Type': 'application/json'};\n    \n    if (curr === true && prev === false) {\n        node.status({fill:'green', shape:'dot', text:'RISING EDGE at ' + new Date().toLocaleTimeString()});\n    } else {\n        node.status({fill:'grey', shape:'ring', text:'OFF at ' + new Date().toLocaleTimeString()});\n    }\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 480,
        "y": 200,
        "wires": [["tb_http_post_l109"]]
    },
